# ─── MediaAssistant + Immich — Synology NAS Configuration ───

# Timezone
TZ=Europe/Zurich

# ─── Paths ───────────────────────────────────────────────────
# Inbox: where new photos/videos are dropped for processing
INBOX_PATH=/volume1/photo/inbox

# Upload/Library: shared between Immich and MediaAssistant
# Immich stores its files here, MediaAssistant reads/writes EXIF tags
UPLOAD_LOCATION=/volume1/photo/library

# ─── Immich ──────────────────────────────────────────────────
IMMICH_VERSION=release

# Database (change the password!)
DB_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/volume1/docker/immich/postgres

# ─── Notes ───────────────────────────────────────────────────
# After first start:
# 1. Open http://nas-ip:2283 → create Immich admin account
# 2. Open http://nas-ip:8000 → MediaAssistant setup wizard
# 3. In MediaAssistant Settings → Immich:
#    - URL: http://immich_server:2283  (internal Docker network)
#    - API Key: create in Immich → User Settings → API Keys
# 4. Configure AI backend URL (e.g. LM Studio on another machine)
