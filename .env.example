# ===========================================================================
# MediaAssistant – Environment Variables
# ===========================================================================
# Copy to .env and adjust values. All variables are optional.
# Variables marked (DB) are imported into the database on first start.
# After that they can be changed via the web interface.
# ===========================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                          # DEBUG, INFO, WARNING, ERROR
TZ=Europe/Zurich                        # Timezone

# ---------------------------------------------------------------------------
# Paths (DB)
# ---------------------------------------------------------------------------
INBOX_PATH=/volume1/inbox               # Default inbox directory
INBOX_LABEL=Default Inbox               # Label for the default inbox
LIBRARY_BASE_PATH=/volume1/library      # Library base path

# ---------------------------------------------------------------------------
# AI Backend (DB)
# ---------------------------------------------------------------------------
AI_BACKEND_URL=http://192.168.0.100:1234/v1    # LM Studio, Ollama etc.
AI_MODEL=qwen/qwen3-vl-4b
# AI_API_KEY=                           # Only if your AI backend requires it

# ---------------------------------------------------------------------------
# Immich (DB)
# ---------------------------------------------------------------------------
# IMMICH_URL=http://192.168.0.100:2283
# IMMICH_API_KEY=

# ---------------------------------------------------------------------------
# Geocoding (DB)
# ---------------------------------------------------------------------------
# GEOCODING_PROVIDER=nominatim          # nominatim, photon, or google
# GEOCODING_URL=                        # Custom geocoding URL
# GOOGLE_MAPS_API_KEY=                  # Only for Google Maps provider

# ---------------------------------------------------------------------------
# SMTP Notifications (DB)
# ---------------------------------------------------------------------------
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_RECIPIENT=user@example.com

# ---------------------------------------------------------------------------
# UI & Processing (DB)
# ---------------------------------------------------------------------------
# UI_LANGUAGE=de                        # de, en
# UI_THEME=dark                         # dark, light
# FILEWATCHER_INTERVAL=5                # Seconds between scans
# FILEWATCHER_SCHEDULE_MODE=continuous  # continuous, window, scheduled, manual
# OCR_MODE=smart                        # smart, all
# PHASH_THRESHOLD=12                    # Duplicate detection threshold (0-64)
# SETUP_COMPLETE=false                  # Set to true to skip the setup wizard

# ---------------------------------------------------------------------------
# Authentication (NOT imported into DB – read directly at startup)
# ---------------------------------------------------------------------------
# AUTH_MODE=disabled                    # disabled or oidc
# OIDC_ISSUER=https://auth.example.com/application/o/mediaassistant/
# OIDC_CLIENT_ID=mediaassistant
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://media.example.com/auth/callback
# OIDC_SCOPES=openid profile email
# SESSION_SECRET=                       # Auto-generated if empty
# SESSION_LIFETIME_HOURS=8
